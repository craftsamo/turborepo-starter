{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs/instructions/*.txt", "apps/**/AGENTS.md"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "wget *": "deny",
      "dd *": "deny",
      ":(){ :|:& }; *": "deny",
      "nps *": "allow"
    }
  }
}
